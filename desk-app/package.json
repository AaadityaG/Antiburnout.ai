{
  "name": "antiburnout",
  "private": true,
  "version": "0.0.0",
  "main": "electron-dist/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:compile": "tsc -b tsconfig.electron.json && node rename-electron.mjs",
    "electron:watch": "concurrently \"tsc -b tsconfig.electron.json --watch\" \"node rename-electron.mjs --watch\"",
    "electron:dev": "npm run electron:compile && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:dev:watch": "concurrently \"npm run electron:watch\" \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run electron:compile && vite build && cross-env NODE_ENV=production electron-builder",
    "electron:build:win": "npm run electron:compile && vite build && cross-env NODE_ENV=production electron-builder --win",
    "electron:build:mac": "npm run electron:compile && vite build && cross-env NODE_ENV=production electron-builder --mac",
    "electron:build:linux": "npm run electron:compile && vite build && cross-env NODE_ENV=production electron-builder --linux"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.3.0",
    "auto-launch": "^5.0.6",
    "axios": "^1.16.1",
    "framer-motion": "^12.42.2",
    "loudness": "^0.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^10.0.0",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.antiburnout.app",
    "productName": "AntiBurnout",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    }
  }
}
